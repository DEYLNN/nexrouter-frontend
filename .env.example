# AI Gateway Next Frontend
# Copy to .env.local for local/VPS test

# Next frontend port
PORT=20129

# Server-side proxy target from Next.js to Hono backend
# Local test backend:
BACKEND_BASE_URL=http://127.0.0.1:18323

# Browser/client-visible backend URL
# If browser can reach backend by public IP/host:
NEXT_PUBLIC_BACKEND_BASE_URL=http://157.173.124.46:18323

# Must match Hono backend JWT_SECRET when frontend/middleware verifies auth token
JWT_SECRET=change-me-same-as-backend

# Use false for HTTP/IP testing. Use true only behind HTTPS domain.
AUTH_COOKIE_SECURE=false

# Frontend-only local data dir; do NOT point this at production backend DB
DATA_DIR=/tmp/ai-gateway-next-frontend
